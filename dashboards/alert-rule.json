{
  "title": "High Request Latency",
  "condition": "A",
  "data": [
    {
      "refId": "A",
      "relativeTimeRange": { "from": 600, "to": 0 },
      "datasourceUid": "grafana-cloudwatch-datasource",
      "model": { 
        "expression": "SELECT AVG(latency) FROM \"BusinessMetrics/Application\" WHERE Latency > 500" 
      }
    }
  ],
  "ruleGroup": "Business-Alerts",
  "for": "1m",
  "annotations": { "summary": "Latency is too high!" }
}
