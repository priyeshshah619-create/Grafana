{
  "uid": "business-observability-dashboard",
  "title": "Business Observability",
  "tags": ["aws", "cloudwatch", "business", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Checkout Error Rate",
      "type": "timeseries",
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "namespace": "Business/App",
          "metricName": "CheckoutErrorRate",
          "dimensions": {"Service": "checkout"},
          "statistics": ["Average"],
          "period": "60",
          "region": "default",
          "matchExact": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 2}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Order Conversion Rate",
      "type": "stat",
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "refId": "A",
          "namespace": "Business/App",
          "metricName": "OrderConversionRate",
          "dimensions": {"Service": "checkout"},
          "statistics": ["Average"],
          "period": "300",
          "region": "default",
          "matchExact": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 95}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Revenue per Minute",
      "type": "bargauge",
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "refId": "A",
          "namespace": "Business/App",
          "metricName": "RevenueAmount",
          "dimensions": {"Service": "checkout", "Currency": "USD"},
          "statistics": ["Sum"],
          "period": "60",
          "region": "default",
          "matchExact": true
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"},
        "overrides": []
      }
    }
  ]
}
