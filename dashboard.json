{
  "title": "Biz Dashboard",
  "panels": [
    {
      "type": "graph",
      "title": "EC2 CPU Trend",
      "targets": [{ "expr": "aws_ec2_cpuutilization_average" }],
      "alert": {
        "name": "High CPU",
        "conditions": [
          {
            "evaluator": { "type": "gt", "params": [80] },
            "operator": { "type": "and" },
            "query": { "params": ["A"] },
            "reducer": { "type": "avg" },
            "type": "query"
          }
        ],
        "notifications": [{ "uid": "sns-template" }]
      }
    }
  ]
}
